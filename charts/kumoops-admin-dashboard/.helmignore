# Patterns to ignore when building Helm packages.
# Operator manifests, OWNERS files, etc.
.DS_Store
# Common VCS dirs
.git/
.gitignore
.bzr/
.bzrignore
.hg/
.hgignore
.svn/
# Common backup files
*.swp
*.bak
*.tmp
*.orig
*~
# Various IDEs
.project
.idea/
*.tmproj
.vscode/

# Chart-local: dev/validation artifacts not meant for the published package
VALIDATION.md
test-invalid-values.yaml
